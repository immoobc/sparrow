# Sparrow 配置模板 - 复制为 .env 使用

# PostgreSQL 连接
# 本地开发: postgresql://root:123456@127.0.0.1:5432/sparrow
# 线上部署: postgresql://moobc:你的复杂密码@127.0.0.1:5432/sparrow
DATABASE_URL=postgresql://root:123456@127.0.0.1:5432/sparrow

# AI 分析（阿里云百炼 DashScope）
AI_API_KEY=sk-your-dashscope-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-max

# 东财限流参数
EM_MIN_INTERVAL=1.0
EM_BATCH_INTERVAL=1.5
EM_DAILY_LIMIT=5000

# 日志级别
LOG_LEVEL=INFO

# 数据存储路径(PDF/CSV等)
DATA_DIR=./data
